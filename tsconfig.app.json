{
  "compilerOptions": {
    "tsBuildInfoFile": "./node_modules/.tmp/tsconfig.app.tsbuildinfo",
    "target": "es2023",
    "lib": ["ES2023", "DOM"],
    "module": "esnext",
    "types": ["vite/client"],
    "skipLibCheck": true,

    /* Bundler mode */
    "moduleResolution": "bundler",
    "allowImportingTsExtensions": true,
    "verbatimModuleSyntax": true,
    "moduleDetection": "force",
    "noEmit": true,
    "jsx": "react-jsx",

    /* Strict (phased): strictNullChecks ONLY for now.
       Deferred strict sub-flags (not enabled yet):
         - strict (the umbrella) — OFF; would pull in all sub-flags below at once.
         - noImplicitAny — OFF; the codebase has many implicit-any params/locals
           whose annotation is a separate, larger mechanical pass (own task).
         - strictFunctionTypes / strictBindCallApply / strictPropertyInitialization /
           alwaysStrict / useUnknownInCatchVariables — OFF; folded into the future
           full-`strict` flip once strictNullChecks has stabilized.
       strictNullChecks is enabled first and in isolation to keep the full strict
       migration as a separate mechanical pass. */
    "strictNullChecks": true,

    /* Linting */
    "noUnusedLocals": true,
    "noUnusedParameters": true,
    "erasableSyntaxOnly": true,
    "noFallthroughCasesInSwitch": true
  },
  "include": ["src"]
}
